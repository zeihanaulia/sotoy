29,"column":28,"offset":1446},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260421162310"}},{"type":"wiki","from":{"fname":"zettel.literature.thoughtworks-ai-native-engineering","id":"zettel.literature.thoughtworks-ai-native-engineering","vaultName":"vault"},"value":"zettel.20260421163750","position":{"start":{"line":30,"column":3,"offset":1554},"end":{"line":30,"column":28,"offset":1579},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260421163750"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":149,"column":3,"offset":13798},"end":{"line":149,"column":59,"offset":13854},"indent":[]},"value":"zettel.literature.thoughtworks-ai-native-engineering"},{"from":{"fname":"zettel.moc.ai-native","id":"zettel.moc.ai-native","vaultName":"vault"},"type":"backlink","position":{"start":{"line":19,"column":3,"offset":1091},"end":{"line":19,"column":59,"offset":1147},"indent":[]},"value":"zettel.literature.thoughtworks-ai-native-engineering"}],"anchors":{"pertanyaan-yang-dibuka":{"type":"header","text":"Pertanyaan yang dibuka","value":"pertanyaan-yang-dibuka","line":14,"column":0,"depth":2},"ringkasan-literatur":{"type":"header","text":"Ringkasan literatur","value":"ringkasan-literatur","line":20,"column":0,"depth":2},"ide-penting":{"type":"header","text":"Ide penting","value":"ide-penting","line":24,"column":0,"depth":2},"interpretasi":{"type":"header","text":"Interpretasi","value":"interpretasi","line":30,"column":0,"depth":2},"sumber":{"type":"header","text":"Sumber","value":"sumber","line":34,"column":0,"depth":2},"lihat-juga":{"type":"header","text":"Lihat juga","value":"lihat-juga","line":38,"column":0,"depth":2}},"children":[],"parent":"ae3bw38eg7l5p3ntry27x87","data":{}},"body":"<h1 id=\"thoughtworks-ai-native-engineering-sebagai-literature-note\">Thoughtworks AI-native engineering sebagai literature note<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#thoughtworks-ai-native-engineering-sebagai-literature-note\"></a></h1>\n<h2 id=\"pertanyaan-yang-dibuka\">Pertanyaan yang dibuka<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-yang-dibuka\"></a></h2>\n<ol>\n<li>Apa definisi AI-native engineering menurut Thoughtworks?</li>\n<li>Bagaimana lima building blocks membentuk model operasional AI-native?</li>\n<li>Apa perbedaan antara AI-native engineering dan sekadar AI-assisted development?</li>\n</ol>\n<h2 id=\"ringkasan-literatur\">Ringkasan literatur<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ringkasan-literatur\"></a></h2>\n<p>Artikel Thoughtworks menggambarkan AI-native engineering sebagai operating model untuk mengorkestrasikan AI, bukan hanya menambahkan AI di sisi coding. Fokusnya pada lima building blocks yang mencakup tata kelola, proses, skil, tooling, dan budaya yang mendukung penggunaan AI secara produktif dan terkontrol.</p>\n<h2 id=\"ide-penting\">Ide penting<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ide-penting\"></a></h2>\n<ul>\n<li>AI-native engineering memperluas tanggung jawab dari coding ke orkestrasi dan verifikasi AI.</li>\n<li>Biasanya diperlukan landasan modern software engineering agar AI tidak mempercepat chaos.</li>\n<li>Building blocks berfungsi sebagai pijakan agar operasional AI bisa diprediksi dan dapat diandalkan.</li>\n</ul>\n<h2 id=\"interpretasi\">Interpretasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#interpretasi\"></a></h2>\n<p>Catatan ini mengkontraskan AI-native bukan sekadar otomatisasi. Thoughtworks menekankan bahwa organisasi perlu membangun sistem kerja yang mendukung AI sebagai rekan kerja, dengan kualitas, tujuan, dan batas yang jelas.</p>\n<h2 id=\"sumber\">Sumber<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sumber\"></a></h2>\n<ul>\n<li><a href=\"https://www.thoughtworks.com/insights/blog/generative-ai/beyond-vibe-coding-the-five-building-blocks-of-aI-native-engineering\">https://www.thoughtworks.com/insights/blog/generative-ai/beyond-vibe-coding-the-five-building-blocks-of-aI-native-engineering</a></li>\n</ul>\n<h2 id=\"lihat-juga\">Lihat juga<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#lihat-juga\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421161001\">AI-native adalah jargon strategi yang menandai asumsi desain AI sebagai fondasi, bukan sekadar fitur tambahan</a> — AI-native adalah jargon strategi yang menandai asumsi desain AI sebagai fondasi, bukan sekadar fitur tambahan</li>\n<li><a href=\"/sotoy/notes/zettel.20260421162310\">AI-native Software Engineering memindahkan gravitasi kerja engineering ke orkestrasi dan verifikasi AI</a> — AI-native Software Engineering memindahkan gravitasi kerja engineering ke orkestrasi dan verifikasi AI</li>\n<li><a href=\"/sotoy/notes/zettel.20260421163750\">Thoughtworks: AI-native engineering adalah operating model untuk mengorkestrasikan AI, bukan sekadar AI coding</a> — Thoughtworks: AI-native engineering adalah operating model untuk mengorkestrasikan AI, bukan sekadar AI coding</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-native (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">thoughtworks (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">literature (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"tem