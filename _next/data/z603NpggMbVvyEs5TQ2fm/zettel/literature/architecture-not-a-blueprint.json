me":"vault"},"value":"zettel.literature.software-architecture-guide","position":{"start":{"line":20,"column":3,"offset":814},"end":{"line":20,"column":52,"offset":863},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.software-architecture-guide"}},{"type":"wiki","from":{"fname":"zettel.literature.architecture-not-a-blueprint","id":"zettel.literature.architecture-not-a-blueprint","vaultName":"vault"},"value":"zettel.literature.architecture-important-stuff","position":{"start":{"line":21,"column":3,"offset":866},"end":{"line":21,"column":53,"offset":916},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.architecture-important-stuff"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":19,"column":3,"offset":956},"end":{"line":19,"column":53,"offset":1006},"indent":[]},"value":"zettel.literature.architecture-not-a-blueprint"},{"from":{"fname":"zettel.20260420060928","id":"zettel.20260420060928","vaultName":"vault"},"type":"backlink","position":{"start":{"line":18,"column":3,"offset":878},"end":{"line":18,"column":53,"offset":928},"indent":[]},"value":"zettel.literature.architecture-not-a-blueprint"},{"from":{"fname":"zettel.literature.enterprise-architecture-coordination-cost","id":"zettel.literature.enterprise-architecture-coordination-cost","vaultName":"vault"},"type":"backlink","position":{"start":{"line":23,"column":3,"offset":983},"end":{"line":23,"column":53,"offset":1033},"indent":[]},"value":"zettel.literature.architecture-not-a-blueprint"},{"from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"type":"backlink","position":{"start":{"line":55,"column":3,"offset":4287},"end":{"line":55,"column":53,"offset":4337},"indent":[]},"value":"zettel.literature.architecture-not-a-blueprint"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":34,"column":3,"offset":1718},"end":{"line":34,"column":53,"offset":1768},"indent":[]},"value":"zettel.literature.architecture-not-a-blueprint"}],"anchors":{"klaim":{"type":"header","text":"Klaim","value":"klaim","line":17,"column":0,"depth":2},"catatan":{"type":"header","text":"Catatan","value":"catatan","line":21,"column":0,"depth":2},"implikasi":{"type":"header","text":"Implikasi","value":"implikasi","line":27,"column":0,"depth":2},"hubungan":{"type":"header","text":"Hubungan","value":"hubungan","line":33,"column":0,"depth":2}},"children":[],"parent":"ae3bw38eg7l5p3ntry27x87","data":{}},"body":"<h1 id=\"arsitektur-bukan-blueprint-terpisah-dari-programming\">Arsitektur bukan blueprint terpisah dari programming<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#arsitektur-bukan-blueprint-terpisah-dari-programming\"></a></h1>\n<h2 id=\"klaim\">Klaim<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#klaim\"></a></h2>\n<p>Fowler curiga pada istilah \"architecture\" karena sering memberi kesan arsitektur terpisah dari programming dan bernuansa elit.</p>\n<h2 id=\"catatan\">Catatan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#catatan\"></a></h2>\n<ul>\n<li>Dia menolak model pikir \"arsitek bikin blueprint, programmer tinggal eksekusi\".</li>\n<li>Arsitektur yang baik harus mendukung evolusinya sendiri dan terintegrasi dengan praktik coding sehari-hari.</li>\n<li>Jika arsitektur hanya hidup di slide atau dokumen terpisah, itu adalah tanda bahaya.</li>\n</ul>\n<h2 id=\"implikasi\">Implikasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#implikasi\"></a></h2>\n<ul>\n<li>Praktik arsitektur harus dilihat sebagai kemampuan judgment teknik yang dipakai dalam development, bukan capaian hierarki.</li>\n<li>Dokumentasi arsitektur harus menjelaskan keputusan yang dipakai dan dievaluasi, bukan sekadar memamerkan diagram.</li>\n<li>Keberhasilan arsitektur bergantung pada keterlibatan langsung developer, bukan pada peran formal \"architect\".</li>\n</ul>\n<h2 id=\"hubungan\">Hubungan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#hubungan\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.software-architecture-guide\">Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.architecture-important-stuff\">Arsitektur adalah apa yang paling penting, bukan hanya struktur tinggi</a></li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a class=\"color-tag\" style=\"--tag-color: #154406;\" href=\"/sotoy/notes/tags.literature-note\">literature-note</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">software-architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">martin-fowler (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">architecture-culture (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420060928\">Arsitektur bukan kasta; dia harus hidup bersama kode</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.enterprise-architecture-coordination-cost\">Enterprise architecture adalah soal biaya koordinasi, bukan kontrol total</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.software-architecture-guide\">Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},