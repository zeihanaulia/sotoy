7,"column":3,"offset":1743},"end":{"line":47,"column":48,"offset":1788},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.bmad-adversarial-review"}},{"type":"wiki","from":{"fname":"zettel.literature.bmad-party-mode","id":"zettel.literature.bmad-party-mode","vaultName":"vault"},"value":"zettel.literature.bmad-advanced-elicitation","position":{"start":{"line":48,"column":3,"offset":1833},"end":{"line":48,"column":50,"offset":1880},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.bmad-advanced-elicitation"}},{"type":"wiki","from":{"fname":"zettel.literature.bmad-party-mode","id":"zettel.literature.bmad-party-mode","vaultName":"vault"},"value":"zettel.moc.ai-native","position":{"start":{"line":49,"column":3,"offset":1927},"end":{"line":49,"column":27,"offset":1951},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.moc.ai-native"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":138,"column":3,"offset":12729},"end":{"line":138,"column":40,"offset":12766},"indent":[]},"value":"zettel.literature.bmad-party-mode"},{"from":{"fname":"zettel.moc.ai-native","id":"zettel.moc.ai-native","vaultName":"vault"},"type":"backlink","position":{"start":{"line":17,"column":3,"offset":932},"end":{"line":17,"column":40,"offset":969},"indent":[]},"value":"zettel.literature.bmad-party-mode"}],"anchors":{"pertanyaan-yang-dibuka":{"type":"header","text":"Pertanyaan yang dibuka","value":"pertanyaan-yang-dibuka","line":15,"column":0,"depth":2},"ringkasan-literatur":{"type":"header","text":"Ringkasan literatur","value":"ringkasan-literatur","line":21,"column":0,"depth":2},"ide-penting":{"type":"header","text":"Ide penting","value":"ide-penting","line":40,"column":0,"depth":2},"interpretasi":{"type":"header","text":"Interpretasi","value":"interpretasi","line":47,"column":0,"depth":2},"sumber":{"type":"header","text":"Sumber","value":"sumber","line":53,"column":0,"depth":2},"lihat-juga":{"type":"header","text":"Lihat juga","value":"lihat-juga","line":57,"column":0,"depth":2}},"children":[],"parent":"ae3bw38eg7l5p3ntry27x87","data":{}},"body":"<h1 id=\"bmad-party-mode-sebagai-literature-note\">BMAD Party Mode sebagai literature note<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#bmad-party-mode-sebagai-literature-note\"></a></h1>\n<h2 id=\"pertanyaan-yang-dibuka\">Pertanyaan yang dibuka<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-yang-dibuka\"></a></h2>\n<ol>\n<li>Mengapa BMAD mengumpulkan banyak agent dalam satu percakapan? </li>\n<li>Bagaimana Party Mode membuat trade-off lebih eksplisit dibandingkan mode agent tunggal? </li>\n<li>Dalam situasi apa Party Mode paling bernilai?</li>\n</ol>\n<h2 id=\"ringkasan-literatur\">Ringkasan literatur<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ringkasan-literatur\"></a></h2>\n<p>Party Mode adalah fitur BMAD untuk mengumpulkan banyak agent dalam satu percakapan yang sama, lalu membiarkan BMAD Master memilih agent relevan untuk merespons setiap pesan.</p>\n<p>Fungsi utamanya adalah membuat perbedaan perspektif terlihat sekaligus. Alih-alih satu agent memberi satu garis reasoning, Party Mode menciptakan percakapan yang menunjukkan tegangan antar reasoning:</p>\n<ul>\n<li>PM</li>\n<li>Architect</li>\n<li>Dev</li>\n<li>UX</li>\n<li>QA/TEA</li>\n</ul>\n<p>Halaman tersebut menempatkan Party Mode sebagai alat yang cocok untuk:</p>\n<ul>\n<li>keputusan besar dengan trade-off,</li>\n<li>sesi brainstorming,</li>\n<li>post-mortem,</li>\n<li>sprint retrospectives/planning.</li>\n</ul>\n<h2 id=\"ide-penting\">Ide penting<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ide-penting\"></a></h2>\n<ul>\n<li>Party Mode adalah \"mesin konflik terkontrol\"; bukan untuk berseteru, tapi untuk memunculkan trade-off.</li>\n<li>Keuntungan utama adalah peta keputusan dari banyak perspektif, bukan jawaban konsensus instan.</li>\n<li>Party Mode komplementer dengan Named Agents, bukan menggantikannya.</li>\n<li>Mode ini efektif ketika masalah kompleks dan multi-peran, tetapi overkill untuk isu kecil.</li>\n</ul>\n<h2 id=\"interpretasi\">Interpretasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#interpretasi\"></a></h2>\n<p>Dengan menggabungkan banyak peran dalam satu ruang diskusi, BMAD Party Mode mengeksternalisasi perbedaan framing yang biasanya tetap tersembunyi di kepala satu pembuat keputusan atau satu reviewer.</p>\n<p>Itu membuat keputusan lebih transparan sekaligus lebih sulit dipaksa oleh satu bias tunggal.</p>\n<h2 id=\"sumber\">Sumber<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sumber\"></a></h2>\n<ul>\n<li><a href=\"https://docs.bmad-method.org/explanation/party-mode/\">https://docs.bmad-method.org/explanation/party-mode/</a></li>\n</ul>\n<h2 id=\"lihat-juga\">Lihat juga<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#lihat-juga\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421185424\">Party Mode adalah mesin konflik terkontrol untuk menampilkan trade-off multi-agent</a> — Party Mode adalah mesin konflik terkontrol untuk menampilkan trade-off multi-agent</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-adversarial-review\">BMAD Adversarial Review sebagai literature note</a> — literature note BMAD Adversarial Review</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-advanced-elicitation\">BMAD Advanced Elicitation sebagai literature note</a> — literature note BMAD Advanced Elicitation</li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a> — MOC AI-native engineering</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">bmad (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">party-mode (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">literature (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-native (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, 