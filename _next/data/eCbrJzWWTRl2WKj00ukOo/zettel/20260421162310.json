":{"line":112,"column":28,"offset":10003},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.20260421162320","id":"zettel.20260421162320","vaultName":"vault"},"type":"backlink","position":{"start":{"line":48,"column":3,"offset":1700},"end":{"line":48,"column":28,"offset":1725},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.20260421192951","id":"zettel.20260421192951","vaultName":"vault"},"type":"backlink","position":{"start":{"line":44,"column":3,"offset":2244},"end":{"line":44,"column":28,"offset":2269},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.20260421193756","id":"zettel.20260421193756","vaultName":"vault"},"type":"backlink","position":{"start":{"line":67,"column":3,"offset":2911},"end":{"line":67,"column":28,"offset":2936},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.literature.thoughtworks-ai-native-engineering","id":"zettel.literature.thoughtworks-ai-native-engineering","vaultName":"vault"},"type":"backlink","position":{"start":{"line":29,"column":3,"offset":1421},"end":{"line":29,"column":28,"offset":1446},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.moc.ai-native","id":"zettel.moc.ai-native","vaultName":"vault"},"type":"backlink","position":{"start":{"line":25,"column":3,"offset":1497},"end":{"line":25,"column":28,"offset":1522},"indent":[]},"value":"zettel.20260421162310"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":40,"column":3,"offset":2404},"end":{"line":40,"column":28,"offset":2429},"indent":[]},"value":"zettel.20260421162310"}],"anchors":{"pertanyaan-yang-dibuka":{"type":"header","text":"Pertanyaan yang dibuka","value":"pertanyaan-yang-dibuka","line":16,"column":0,"depth":2},"klaim-utama":{"type":"header","text":"Klaim utama","value":"klaim-utama","line":22,"column":0,"depth":2},"gravitasi-kerja-di-tiga-mode":{"type":"header","text":"Gravitasi kerja di tiga mode","value":"gravitasi-kerja-di-tiga-mode","line":26,"column":0,"depth":2},"konsekuensi-perubahan-gravitasi":{"type":"header","text":"Konsekuensi perubahan gravitasi","value":"konsekuensi-perubahan-gravitasi","line":32,"column":0,"depth":2},"classic":{"type":"header","text":"Classic","value":"classic","line":34,"column":0,"depth":3},"modern":{"type":"header","text":"Modern","value":"modern","line":40,"column":0,"depth":3},"ai-native":{"type":"header","text":"AI-native","value":"ai-native","line":46,"column":0,"depth":3},"titik-beratnya-berubah":{"type":"header","text":"Titik beratnya berubah","value":"titik-beratnya-berubah","line":52,"column":0,"depth":2},"peringatan":{"type":"header","text":"Peringatan","value":"peringatan","line":59,"column":0,"depth":2},"lihat-juga":{"type":"header","text":"Lihat juga","value":"lihat-juga","line":65,"column":0,"depth":2}},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"ai-native-software-engineering-memindahkan-gravitasi-kerja-engineering-ke-orkestrasi-dan-verifikasi-ai\">AI-native Software Engineering memindahkan gravitasi kerja engineering ke orkestrasi dan verifikasi AI<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ai-native-software-engineering-memindahkan-gravitasi-kerja-engineering-ke-orkestrasi-dan-verifikasi-ai\"></a></h1>\n<h2 id=\"pertanyaan-yang-dibuka\">Pertanyaan yang dibuka<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-yang-dibuka\"></a></h2>\n<ol>\n<li>Di mana letak tenaga utama engineering bergeser saat bergerak ke AI-native?</li>\n<li>Apa perbedaan antara energy source di Classic, Modern, dan AI-native SE?</li>\n<li>Kenapa ini bukan sekadar perkembangan linear dari modern SE?</li>\n</ol>\n<h2 id=\"klaim-utama\">Klaim utama<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#klaim-utama\"></a></h2>\n<p>AI-native Software Engineering bukan lagi tentang manusia menulis sebagian besar kode. Pusat tenaga utama berpindah dari implementasi manual ke orkestrasi intent, konteks, constraint, dan verifikasi output AI.</p>\n<h2 id=\"gravitasi-kerja-di-tiga-mode\">Gravitasi kerja di tiga mode<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#gravitasi-kerja-di-tiga-mode\"></a></h2>\n<ul>\n<li>Classic: tenaga utama di coding manual dan prosedur manusia.</li>\n<li>Modern: tenaga utama di automasi pipeline dan arsitektur delivery.</li>\n<li>AI-native: tenaga utama di orkestrasi intent, constraint, context, dan verifikasi output AI.</li>\n</ul>\n<h2 id=\"konsekuensi-perubahan-gravitasi\">Konsekuensi perubahan gravitasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#konsekuensi-perubahan-gravitasi\"></a></h2>\n<h3 id=\"classic\">Classic<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#classic\"></a></h3>\n<ul>\n<li>Engineering energy spent on writing code and executing manual workflows.</li>\n<li>Tools are passive helpers.</li>\n<li>Result: high control, low speed, high bottleneck.</li>\n</ul>\n<h3 id=\"modern\">Modern<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#modern\"></a></h3>\n<ul>\n<li>Engineering energy spent on designing delivery systems and maintaining automation.</li>\n<li>Tools become active guards for quality and speed.</li>\n<li>Result: faster delivery, more repeatable process, but code generation still human-led.</li>\n</ul>\n<h3 id=\"ai-native\">AI-native<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ai-native\"></a></h3>\n<ul>\n<li>Engineering energy spent on defining what should happen, why, and under what constraints.</li>\n<li>AI acts as operational collaborator that writes, tests, and proposes changes.</li>\n<li>Result: faster multi-file change, but output requires strong human oversight.</li>\n</ul>\n<h2 id=\"titik-beratnya-berubah\">Titik beratnya berubah<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#titik-beratnya-berubah\"></a></h2>\n<ol>\n<li>Intent dan spesifikasi menjadi input utama.</li>\n<li>Context engineering menjadi fungsi kritis.</li>\n<li>Guardrail dan trust model menjadi bagian kerja sehari-hari.</li>\n<li>Review manusia berubah dari memeriksa kode ke memeriksa keputusan AI.</li>\n</ol>\n<h2 id=\"peringatan\">Peringatan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#peringatan\"></a></h2>\n<p>AI-native bukan berarti kerja manusia hilang. Alih-alih, peran manusia bergeser dari \"penulis\" ke \"penentu batas\"</p>\n<ul>\n<li>Jika human review melemah, AI-native bisa jadi false confidence machine.</li>\n<li>Jika context miskin, AI menghasilkan output generik yang tampak benar.</li>\n</ul>\n<h2 id=\"lihat-juga\">Lihat juga<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#lihat-juga\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421162253\">Classic, Modern, dan AI-native Software Engineering adalah tiga mode kerja, bukan disiplin formal</a> — Classic, Modern, dan AI-native Software Engineering adalah tiga mode kerja, bukan disiplin formal</li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-native (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">software-engineering (Private)</a></li>\n<li><a class=\"color-tag\" style=\"--tag-color: #ff9a8a;\" href=\"/sotoy/notes/tags.workflow\">workflow</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421162320\">AI-native Software Engineering membutuhkan fondasi Modern SE agar tidak mempercepat chaos</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421192951\">Spec semakin penting ketika AI bisa menulis kode, bukan hanya karena kode lebih murah</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421193756\">Spec Kit tetap relevan sebagai pipeline spesifikasi meski banyak framework AI-native muncul</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.thoughtworks-ai-native-engineering\">Thoughtworks AI-native engineering sebagai literature note</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"dendronVersion":"0.83.0","vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y.MM.dd","addBehavior":"childOfDomain"},"scratch":{"name":"scratch","dateFormat":"y.MM.dd.HHmmss","addBehavior":"asOwnDomain"},"task":{"name":"","dateFormat":"","addBehavior":"childOfCurrent","statusSymbols":{"":" ","wip":"w","done":"x","assigned":"a","moved":"m","blocked":"b","delegated":"l","dropped":"d","pending":"y"},"prioritySymbols":{"H":"high","M":"medium","L":"low"},"todoIntegration":false,"createTaskSelectionType":"selection2link","taskCompleteStatus":["done","x"]},"graph":{"zoomSpeed":1,"createStub":false},"enableAutoCreateOnDefinition":false,"enableXVaultWikiLink":false,"enableRemoteVaultInit":true,"enableUserTags":true,"enableHashTags":true,"workspaceVaultSyncMode":"noCommit","enableAutoFoldFrontmatter":false,"enableEditorDecorations":true,"maxPreviewsCached":10,"maxNoteLength":204800,"seeds":{"dendron.templates":{}},"enableFullHierarchyNoteTitle":false},"preview":{"enableFMTitle":true,"enableNoteTitleForLink":true,"enableFrontmatterTags":true,"enableHashesForFMTags":false,"enablePrettyRefs":true,"enableKatex":true,"automaticallyShowPreview":false},"publishing":{"enableFMTitle":true,"enabl