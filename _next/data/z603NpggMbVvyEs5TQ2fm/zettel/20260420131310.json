{"pageProps":{"note":{"id":"zettel.20260420131310","title":"Percakapan AI adalah medium berpikir, bukan tempat penyimpanan keputusan","desc":"Chat AI memang buat mikir, bukan buat nyimpen keputusan fitur.","tags":["zettel","ai-collaboration","knowledge-management","context-anchoring"],"custom":{},"fname":"zettel.20260420131310","type":"note","vault":{"fsPath":"vault"},"contentHash":"15eac3fb2854d34f06778c7e39b526bd","updated":1776683200449,"created":1776683200449,"links":[{"type":"frontmatterTag","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"tags.zettel","alias":"zettel","xvault":false,"to":{"fname":"tags.zettel"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"tags.ai-collaboration","alias":"ai-collaboration","xvault":false,"to":{"fname":"tags.ai-collaboration"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"tags.knowledge-management","alias":"knowledge-management","xvault":false,"to":{"fname":"tags.knowledge-management"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"tags.context-anchoring","alias":"context-anchoring","xvault":false,"to":{"fname":"tags.context-anchoring"}},{"type":"wiki","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"zettel.literature.context-anchoring","position":{"start":{"line":36,"column":14,"offset":1870},"end":{"line":36,"column":53,"offset":1909},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.context-anchoring"}},{"type":"wiki","from":{"fname":"zettel.20260420131310","id":"zettel.20260420131310","vaultName":"vault"},"value":"zettel.20260420131311","position":{"start":{"line":37,"column":15,"offset":1957},"end":{"line":37,"column":40,"offset":1982},"indent":[]},"xvault":false,"sa