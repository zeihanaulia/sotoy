ttel.literature.bmad-advanced-elicitation"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":146,"column":3,"offset":13521},"end":{"line":146,"column":28,"offset":13546},"indent":[]},"value":"zettel.20260421184856"},{"from":{"fname":"zettel.20260421184757","id":"zettel.20260421184757","vaultName":"vault"},"type":"backlink","position":{"start":{"line":40,"column":3,"offset":1877},"end":{"line":40,"column":28,"offset":1902},"indent":[]},"value":"zettel.20260421184856"},{"from":{"fname":"zettel.literature.bmad-advanced-elicitation","id":"zettel.literature.bmad-advanced-elicitation","vaultName":"vault"},"type":"backlink","position":{"start":{"line":28,"column":3,"offset":1040},"end":{"line":28,"column":28,"offset":1065},"indent":[]},"value":"zettel.20260421184856"},{"from":{"fname":"zettel.moc.ai-native","id":"zettel.moc.ai-native","vaultName":"vault"},"type":"backlink","position":{"start":{"line":64,"column":3,"offset":5717},"end":{"line":64,"column":28,"offset":5742},"indent":[]},"value":"zettel.20260421184856"}],"anchors":{"pertanyaan-yang-dibuka":{"type":"header","text":"Pertanyaan yang dibuka","value":"pertanyaan-yang-dibuka","line":15,"column":0,"depth":2},"klaim-utama":{"type":"header","text":"Klaim utama","value":"klaim-utama","line":21,"column":0,"depth":2},"penjelasan":{"type":"header","text":"Penjelasan","value":"penjelasan","line":25,"column":0,"depth":2},"contoh":{"type":"header","text":"Contoh","value":"contoh","line":29,"column":0,"depth":2},"implikasi":{"type":"header","text":"Implikasi","value":"implikasi","line":33,"column":0,"depth":2},"lihat-juga":{"type":"header","text":"Lihat juga","value":"lihat-juga","line":38,"column":0,"depth":2}},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"stakeholder-mapping-membuka-risiko-lewat-banyak-perspektif\">Stakeholder mapping membuka risiko lewat banyak perspektif<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#stakeholder-mapping-membuka-risiko-lewat-banyak-perspektif\"></a></h1>\n<h2 id=\"pertanyaan-yang-dibuka\">Pertanyaan yang dibuka<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-yang-dibuka\"></a></h2>\n<ol>\n<li>Bagaimana metode ini mengubah cara artefak diperiksa?</li>\n<li>Apa asumsi tersembunyi yang biasanya terbuka dengan cara ini?</li>\n<li>Kapan metode ini cocok dipakai dalam workflow AI-native?</li>\n</ol>\n<h2 id=\"klaim-utama\">Klaim utama<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#klaim-utama\"></a></h2>\n<p>Stakeholder mapping melihat artefak dari sudut berbagai aktor, sehingga konflik tujuan dan missing concern menjadi terlihat lebih cepat.</p>\n<h2 id=\"penjelasan\">Penjelasan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#penjelasan\"></a></h2>\n<p>Metode ini memetakan kebutuhan, kekhawatiran, dan tujuan setiap pihak yang terkait, lalu menilai artefak berdasarkan perspektif tersebut.</p>\n<h2 id=\"contoh\">Contoh<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#contoh\"></a></h2>\n<p>Untuk dokumen release plan, mapping dapat mengungkap bahwa ops butuh observability, support butuh error message jelas, dan compliance butuh audit trail.</p>\n<h2 id=\"implikasi\">Implikasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#implikasi\"></a></h2>\n<ul>\n<li>Penting untuk artefak yang melibatkan banyak fungsi atau pihak eksternal.</li>\n<li>Mengurangi bias internal yang muncul saat artefak hanya dinilai dari satu POV.</li>\n</ul>\n<h2 id=\"lihat-juga\">Lihat juga<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#lihat-juga\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421184757\">Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</a> — Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-advanced-elicitation\">BMAD Advanced Elicitation sebagai literature note</a> — literature note BMAD Advanced Elicitation</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">bmad (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">stakeholder-mapping (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-native (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">reasoning (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184757\">Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-advanced-elicitation\">BMAD Advanced Elicitation sebagai literature note</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"dendronVersion":"0.83.0","vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y.MM.dd","addBehavior":"childOfDomain"},"scratch":{"name":"scratch","dateFormat":"y.MM.dd.HHmmss","addBehavior":"asOwnDomain"},"task":{"name":"","dateFormat":"","addBehavior":"childOfCurrent","statusSymbols":{"":" ","wip":"w","done":"x","assigned":"a","moved":"m","blocked":"b","delegated":"l","dropped":"d","pending":"y"},"prioritySymbols":{"H":"high","M":"medium","L":"low"},"todoIntegration":false,"cre