olumn":3,"offset":995},"end":{"line":21,"column":53,"offset":1045},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.architecture-important-stuff"}},{"type":"wiki","from":{"fname":"zettel.20260420061530","id":"zettel.20260420061530","vaultName":"vault"},"value":"zettel.20260420061232","position":{"start":{"line":22,"column":3,"offset":1122},"end":{"line":22,"column":28,"offset":1147},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260420061232"}},{"type":"wiki","from":{"fname":"zettel.20260420061530","id":"zettel.20260420061530","vaultName":"vault"},"value":"zettel.20260420061356","position":{"start":{"line":23,"column":3,"offset":1204},"end":{"line":23,"column":28,"offset":1229},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260420061356"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":54,"column":3,"offset":4202},"end":{"line":54,"column":28,"offset":4227},"indent":[]},"value":"zettel.20260420061530"},{"from":{"fname":"zettel.20260420062009","id":"zettel.20260420062009","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1157},"end":{"line":22,"column":28,"offset":1182},"indent":[]},"value":"zettel.20260420061530"},{"from":{"fname":"zettel.20260420062331","id":"zettel.20260420062331","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1343},"end":{"line":22,"column":28,"offset":1368},"indent":[]},"value":"zettel.20260420061530"},{"from":{"fname":"zettel.20260420085349","id":"zettel.20260420085349","vaultName":"vault"},"type":"backlink","position":{"start":{"line":23,"column":3,"offset":1223},"end":{"line":23,"column":28,"offset":1248},"indent":[]},"value":"zettel.20260420061530"},{"from":{"fname":"zettel.20260420090829","id":"zettel.20260420090829","vaultName":"vault"},"type":"backlink","position":{"start":{"line":28,"column":3,"offset":1606},"end":{"line":28,"column":28,"offset":1631},"indent":[]},"value":"zettel.20260420061530"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":87,"column":3,"offset":7230},"end":{"line":87,"column":28,"offset":7255},"indent":[]},"value":"zettel.20260420061530"}],"anchors":{},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"architecture-adalah-seni-memilah-keputusan-penting\">Architecture adalah seni memilah keputusan penting<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#architecture-adalah-seni-memilah-keputusan-penting\"></a></h1>\n<blockquote>\n<p>\"Architecture is about the important stuff. Whatever that is.\"</p>\n<p>Sumber: <a href=\"https://martinfowler.com/architecture/\">https://martinfowler.com/architecture/</a></p>\n</blockquote>\n<p>Catatan gue:</p>\n<ul>\n<li>Ini adalah kalimat pusat halaman Fowler: arsitektur bukan definisi bentuk, melainkan definisi prioritas perhatian.</li>\n<li>Permainan arsitektural adalah mengenali keputusan yang benar-benar penting dan merawatnya agar tetap sehat.</li>\n<li>Bukan semua hal penting sama penting; yang krusial adalah keputusan yang bila diabaikan akan memicu masalah besar.</li>\n</ul>\n<p>Implikasi:</p>\n<ul>\n<li>Arsitektur harus fokus pada item yang menyebabkan coupling, isu operasional, batas domain, integrasi, deployment, dan data ownership jika salah.</li>\n<li>Definisi arsitektur harus bisa dievaluasi berdasarkan seberapa baik keputusan penting itu dijaga, bukan seberapa lengkap diagramnya.</li>\n<li>Tim harus belajar memilah antara detail implementasi dan elemen yang layak mendapat perhatian arsitektural.</li>\n</ul>\n<p>Hubungan:</p>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.software-architecture-guide\">Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah</a> — ringkasan halaman Software Architecture Guide</li>\n<li><a href=\"/sotoy/notes/zettel.literature.architecture-important-stuff\">Arsitektur adalah apa yang paling penting, bukan hanya struktur tinggi</a> — arsitektur sebagai apa yang paling penting, bukan hanya struktur tinggi</li>\n<li><a href=\"/sotoy/notes/zettel.20260420061232\">Fowler memulai definisi arsitektur dengan kritik terhadap ‘fundamental organization’</a> — kritik terhadap definisi \"fundamental organization\"</li>\n<li><a href=\"/sotoy/notes/zettel.20260420061356\">Arsitektur bukan sekadar keputusan awal proyek</a> — arsitektur bukan sekadar keputusan awal proyek</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">permanent-note (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">software-architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">martin-fowler (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420062009\">Architect bukan jabatan; dia adalah kemampuan judgment desain</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420062331\">Internal quality adalah infrastruktur kecepatan delivery</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420085349\">Keputusan arsitektural penting bergantung pada skala sistem</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090829\">Presentation Domain Data Layering adalah baseline, bukan arsitektur kuno</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"al