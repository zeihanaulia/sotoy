{"pageProps":{"note":{"id":"zettel.literature.software-architecture-guide","title":"Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah","desc":"Catatan literatur dari halaman Martin Fowler yang memetakan software architecture sebagai peta keputusan, bukan sekadar diagram.","tags":["literature-note","software-architecture","martin-fowler","decision-making"],"source":"https://martinfowler.com/architecture/","custom":{"source":"https://martinfowler.com/architecture/"},"fname":"zettel.literature.software-architecture-guide","type":"note","vault":{"fsPath":"vault"},"contentHash":"46dfeee427ee37df76711cd4689d64bf","updated":1776683201779,"created":1776683201779,"links":[{"type":"frontmatterTag","from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"value":"tags.literature-note","alias":"literature-note","xvault":false,"to":{"fname":"tags.literature-note"}},{"type":"frontmatterTag","from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"value":"tags.software-architecture","alias":"software-architecture","xvault":false,"to":{"fname":"tags.software-architecture"}},{"type":"frontmatterTag","from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"value":"tags.martin-fowler","alias":"martin-fowler","xvault":false,"to":{"fname":"tags.martin-fowler"}},{"type":"frontmatterTag","from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"value":"tags.decision-making","alias":"decision-making","xvault":false,"to":{"fname":"tags.decision-making"}},{"type":"wiki","from":{"fname":"zettel.literature.software-architecture-guide","id":"zettel.literature.software-architecture-guide","vaultName":"vault"},"value":"zettel.2026