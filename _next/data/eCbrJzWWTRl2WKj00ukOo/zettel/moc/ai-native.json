et":3184},"indent":[]},"value":"zettel.moc.ai-native"},{"from":{"fname":"zettel.20260421193757","id":"zettel.20260421193757","vaultName":"vault"},"type":"backlink","position":{"start":{"line":67,"column":3,"offset":2280},"end":{"line":67,"column":27,"offset":2304},"indent":[]},"value":"zettel.moc.ai-native"},{"from":{"fname":"zettel.literature.bmad-advanced-elicitation","id":"zettel.literature.bmad-advanced-elicitation","vaultName":"vault"},"type":"backlink","position":{"start":{"line":51,"column":3,"offset":2080},"end":{"line":51,"column":27,"offset":2104},"indent":[]},"value":"zettel.moc.ai-native"},{"from":{"fname":"zettel.literature.bmad-party-mode","id":"zettel.literature.bmad-party-mode","vaultName":"vault"},"type":"backlink","position":{"start":{"line":49,"column":3,"offset":1927},"end":{"line":49,"column":27,"offset":1951},"indent":[]},"value":"zettel.moc.ai-native"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":63,"column":3,"offset":4944},"end":{"line":63,"column":27,"offset":4968},"indent":[]},"value":"zettel.moc.ai-native"}],"anchors":{"apa-yang-terkandung-di-sini":{"type":"header","text":"Apa yang terkandung di sini","value":"apa-yang-terkandung-di-sini","line":14,"column":0,"depth":2},"literatur-bmad-dan-ai-native":{"type":"header","text":"Literatur BMAD dan AI-native","value":"literatur-bmad-dan-ai-native","line":18,"column":0,"depth":2},"permanent-note-bmad--ai-native":{"type":"header","text":"Permanent note BMAD / AI-native","value":"permanent-note-bmad--ai-native","line":33,"column":0,"depth":2},"link-penting-ke-mana-selanjutnya":{"type":"header","text":"Link penting ke mana selanjutnya","value":"link-penting-ke-mana-selanjutnya","line":80,"column":0,"depth":2}},"children":[],"parent":"6ie1ckeu7jfftzq54vt9e44","data":{}},"body":"<h1 id=\"moc-ai-native-engineering\">MOC AI-native engineering<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#moc-ai-native-engineering\"></a></h1>\n<h2 id=\"apa-yang-terkandung-di-sini\">Apa yang terkandung di sini<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#apa-yang-terkandung-di-sini\"></a></h2>\n<p>Catatan ini mengumpulkan semua literatur, konsep, dan simulasi BMAD / AI-native yang sudah didokumentasikan di vault.</p>\n<h2 id=\"literatur-bmad-dan-ai-native\">Literatur BMAD dan AI-native<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#literatur-bmad-dan-ai-native\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-overview\">BMAD overview sebagai literature note</a> — overview BMAD docs</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-getting-started\">BMAD Getting Started sebagai literature note</a> — literature note BMAD Getting Started</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-analysis-phase\">BMAD Analysis Phase sebagai literature note</a> — literature note BMAD Analysis Phase</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-brainstorming\">BMAD Brainstorming sebagai literature note</a> — literature note BMAD Brainstorming</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-named-agents\">BMAD Named Agents sebagai literature note</a> — literature note BMAD Named Agents</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-quick-dev\">BMAD Quick Dev sebagai literature note</a> — literature note BMAD Quick Dev</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-preventing-agent-conflicts\">BMAD Preventing Agent Conflicts sebagai literature note</a> — literature note BMAD Preventing Agent Conflicts</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-adversarial-review\">BMAD Adversarial Review sebagai literature note</a> — literature note BMAD Adversarial Review</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-advanced-elicitation\">BMAD Advanced Elicitation sebagai literature note</a> — literature note BMAD Advanced Elicitation</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-party-mode\">BMAD Party Mode sebagai literature note</a> — literature note BMAD Party Mode</li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">zettel.literature.checkpoint-preview (Private)</a> — literature note BMAD Checkpoint Preview</li>\n<li><a href=\"/sotoy/notes/zettel.literature.thoughtworks-ai-native-engineering\">Thoughtworks AI-native engineering sebagai literature note</a> — Thoughtworks AI-native engineering</li>\n</ul>\n<h2 id=\"permanent-note-bmad--ai-native\">Permanent note BMAD / AI-native<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#permanent-note-bmad--ai-native\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421170516\">BMAD adalah framework workflow AI-native engineering yang mengganti prompt chaos dengan peran dan fase terstruktur</a> — BMAD adalah framework workflow AI-native engineering yang mengganti prompt chaos dengan peran dan fase terstruktur</li>\n<li><a href=\"/sotoy/notes/zettel.20260421162253\">Classic, Modern, dan AI-native Software Engineering adalah tiga mode kerja, bukan disiplin formal</a> — Classic, Modern, dan AI-native Software Engineering adalah tiga mode kerja, bukan disiplin formal</li>\n<li><a href=\"/sotoy/notes/zettel.20260421162310\">AI-native Software Engineering memindahkan gravitasi kerja engineering ke orkestrasi dan verifikasi AI</a> — AI-native Software Engineering memindahkan gravitasi kerja engineering ke orkestrasi dan verifikasi AI</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193300\">Model dan agent adalah fungsi berbeda dalam AI-native engineering</a> — Model dan agent adalah fungsi berbeda dalam AI-native engineering</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193301\">Methodology wajib ada supaya AI-assisted development tidak jadi chaos yang efisien</a> — Methodology wajib ada supaya AI-assisted development tidak jadi chaos yang efisien</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193302\">Context engineering adalah menyusun constraint lokal, bukan sekadar menambahkan informasi</a> — Context engineering adalah menyusun constraint lokal, bukan sekadar menambahkan informasi</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193303\">BMAD duduk di lapisan methodology dan orchestration, bukan sekadar prompt atau persona</a> — BMAD duduk di lapisan methodology dan orchestration, bukan sekadar prompt atau persona</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193304\">Planning harus dipisah dari solutioning agar requirement dan teknikal decision tetap jernih</a> — Planning harus dipisah dari solutioning agar requirement dan teknikal decision tetap jernih</li>\n<li><a href=\"/sotoy/notes/zettel.20260421162320\">AI-native Software Engineering membutuhkan fondasi Modern SE agar tidak mempercepat chaos</a> — AI-native Software Engineering membutuhkan fondasi Modern SE agar tidak mempercepat chaos</li>\n<li><a href=\"/sotoy/notes/zettel.20260421192951\">Spec semakin penting ketika AI bisa menulis kode, bukan hanya karena kode lebih murah</a> — Spec semakin penting ketika AI bisa menulis kode, bukan hanya karena kode lebih murah</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193756\">Spec Kit tetap relevan sebagai pipeline spesifikasi meski banyak framework AI-native muncul</a> — Spec Kit tetap relevan sebagai pipeline spesifikasi meski banyak framework AI-native muncul</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193757\">Kapan struktur AI-native jadi layak dipakai dan kapan ia justru overkill</a> — Kapan struktur AI-native jadi layak dipakai dan kapan ia justru overkill</li>\n<li><a href=\"/sotoy/notes/zettel.20260421170812\">BMAD Getting Started mengajarkan workflow awal AI-native engineering, bukan sekadar installasi</a> — BMAD Getting Started mengajarkan workflow awal AI-native engineering, bukan sekadar installasi</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171457\">BMAD analysis phase menghentikan ketidakjelasan sebelum berubah jadi PRD dan architecture</a> — BMAD analysis phase menghentikan ketidakjelasan sebelum berubah jadi PRD dan architecture</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171633\">BMAD brainstorming memperjelas ide sebelum requirement</a> — BMAD brainstorming memperjelas ide sebelum requirement</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171634\">BMAD market research menangkap realitas eksternal sebelum planning</a> — BMAD market research menangkap realitas eksternal sebelum planning</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171635\">BMAD domain research memaksa pemahaman logika industri sebelum solusi</a> — BMAD domain research memaksa pemahaman logika industri sebelum solusi</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171636\">BMAD technical research memvalidasi feasibility sebelum architecture</a> — BMAD technical research memvalidasi feasibility sebelum architecture</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171637\">BMAD product brief merapikan visi produk sebelum PRD</a> — BMAD product brief merapikan visi produk sebelum PRD</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171638\">BMAD PRFAQ menguji ide dengan pendekatan adversarial sebelum planning</a> — BMAD PRFAQ menguji ide dengan pendekatan adversarial sebelum planning</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171823\">BMAD analysis phase sebagai epistemic filter sebelum PRD</a> — BMAD analysis phase sebagai epistemic filter sebelum PRD</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171824\">BMAD Product Brief vs PRFAQ: klarifikasi lembut versus pengujian adversarial</a> — BMAD Product Brief vs PRFAQ: klarifikasi lembut versus pengujian adversarial</li>\n<li><a href=\"/sotoy/notes/zettel.20260421171825\">Simulasi BMAD analysis phase: invoice app untuk freelancer</a> — Simulasi BMAD analysis phase: invoice app untuk freelancer</li>\n<li><a href=\"/sotoy/notes/zettel.20260421172430\">BMAD named agents membangun AI coworker model, bukan sekadar persona lucu</a> — BMAD named agents membangun AI coworker model, bukan sekadar persona lucu</li>\n<li><a href=\"/sotoy/notes/zettel.20260421172636\">BMAD activation flow dan customization: menyusun agent dari template, konteks, dan kebiasaan tim</a> — BMAD activation flow dan customization: menyusun agent dari template, konteks, dan kebiasaan tim</li>\n<li><a href=\"/sotoy/notes/zettel.20260421173427\">AI brainstorming terbaik adalah fasilitasi kondisi insight, bukan generator ide</a> — AI brainstorming terbaik adalah fasilitasi kondisi insight, bukan generator ide</li>\n<li><a href=\"/sotoy/notes/zettel.20260421173600\">Simulasi BMAD brainstorming: dari keresahan tim kecil AI coding tools ke problem definition</a> — Simulasi BMAD brainstorming: dari keresahan tim kecil AI coding tools ke problem definition</li>\n<li><a href=\"/sotoy/notes/zettel.20260421174123\">BMAD Quick Dev mengoptimalkan attention manusia, bukan sekadar kecepatan model</a> — BMAD Quick Dev mengoptimalkan attention manusia, bukan sekadar kecepatan model</li>\n<li><a href=\"/sotoy/notes/zettel.20260421193440\">PATCH, BAD SPEC, dan INTENT GAP: diagnosis kegagalan dalam workflow AI-native</a> — PATCH, BAD SPEC, dan INTENT GAP: diagnosis kegagalan dalam workflow AI-native</li>\n<li><a href=\"/sotoy/notes/zettel.20260421174751\">Quick Dev diagram: node-by-node diagnosis layer dan alur koreksi</a> — Quick Dev diagram: node-by-node diagnosis layer dan alur koreksi</li>\n<li><a href=\"/sotoy/notes/zettel.20260421175034\">Simulasi Quick Dev: reset password via email menunjukkan PATCH, BAD SPEC, dan INTENT GAP</a> — simulasi Quick Dev: reset password via email menunjukkan PATCH, BAD SPEC, dan INTENT GAP</li>\n<li><a href=\"/sotoy/notes/zettel.20260421180059\">Checkpoint Preview membuat review manusia fokus pada pemahaman, bukan sekadar diff</a> — Checkpoint Preview membuat review manusia fokus pada pemahaman, bukan sekadar diff</li>\n<li><a href=\"/sotoy/notes/zettel.20260421183954\">Preventing Agent Conflicts membangun shared context, bukan mengandalkan agent tunggal</a> — Preventing Agent Conflicts membangun shared context, bukan mengandalkan agent tunggal</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184439\">Adversarial Review memaksa reviewer beralih dari rasa aman ke pencarian kelemahan</a> — Adversarial Review memaksa reviewer beralih dari rasa aman ke pencarian kelemahan</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184757\">Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</a> — Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</li>\n<li><a href=\"/sotoy/notes/zettel.20260421191335\">Pre-mortem bisa dilakukan tanpa event nyata dengan asumsi terstruktur, bukan nebak-nebak acak</a> — Pre-mortem bisa dilakukan tanpa event nyata dengan asumsi terstruktur</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184801\">Pre-mortem analysis memaksa perencanaan menilai hasil dengan asumsi kegagalan</a> — Pre-mortem analysis memaksa perencanaan menilai hasil dengan asumsi kegagalan</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184812\">First principles thinking menuntut solusi dibangun dari fakta paling dasar</a> — First principles thinking menuntut solusi dibangun dari fakta paling dasar</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184823\">Inversion mencari jalur gagal untuk menguji validitas desain</a> — Inversion mencari jalur gagal untuk menguji validitas desain</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184834\">Red team vs blue team menguji ketahanan argumen lewat serangan dan pembelaan</a> — Red team vs blue team menguji ketahanan argumen lewat serangan dan pembelaan</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184845\">Socratic questioning mengungkap asumsi lewat pertanyaan terarah</a> — Socratic questioning mengungkap asumsi lewat pertanyaan terarah</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184856\">Stakeholder mapping membuka risiko lewat banyak perspektif</a> — Stakeholder mapping membuka risiko lewat banyak perspektif</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184907\">Constraint removal mengecek apakah batasan itu nyata atau sekadar asumsi</a> — Constraint removal mengecek apakah batasan itu nyata atau sekadar asumsi</li>\n<li><a href=\"/sotoy/notes/zettel.20260421172800\">BMAD project context adalah konstitusi implementasi untuk AI agents, bukan dokumentasi biasa</a> — BMAD project context adalah konstitusi implementasi untuk AI agents, bukan dokumentasi biasa</li>\n</ul>\n<h2 id=\"link-penting-ke-mana-selanjutnya\">Link penting ke mana selanjutnya<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#link-penting-ke-mana-selanjutnya\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a> — entry point arsitektur yang lebih luas</li>\n<li><a href=\"/sotoy/notes/zettel.20260421161001\">AI-native adalah jargon strategi yang menandai asumsi desain AI sebagai fondasi, bukan sekadar fitur tambahan</a> — definisi AI-native sebagai asumsi dasar desain</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a class=\"color-tag\" style=\"--tag-color: #edc8ff;\" href=\"/sotoy/notes/tags.moc\">moc</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-native (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">bmad (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421183954\">Preventing Agent Conflicts membangun shared context, bukan mengandalkan agent tunggal</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184439\">Adversarial Review memaksa reviewer beralih dari rasa aman ke pencarian kelemahan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184757\">Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421185424\">Party Mode adalah mesin konflik terkontrol untuk menampilkan trade-off multi-agent</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421192951\">Spec semakin penting ketika AI bisa menulis kode, bukan hanya karena kode lebih murah</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421193440\">PATCH, BAD SPEC, dan INTENT GAP: diagnosis kegagalan dalam workflow AI-native</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421193756\">Spec Kit tetap relevan sebagai pipeline spesifikasi meski banyak framework AI-native muncul</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421193757\">Kapan struktur AI-native jadi layak dipakai dan kapan ia justru overkill</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-advanced-elicitation\">BMAD Advanced Elicitation sebagai literature note</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-party-mode\">BMAD Party Mode sebagai literature note</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"dendronVersion":"0.83.0","vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y.MM.dd","addBehavior":"childOfDomain"},"scratch":{"name":"scratch","dateFormat":"y.MM.dd.HHmmss","addBehavior":"asOwnDomain"},"task":{"name":"","dateFormat":"","addBehavior":"childOfCurrent","statusSymbols":{"":" ","wip":"w","done":"x","assigned":"a","moved":"m","blocked":"b","delegated":"l","dropped":"d","pending":"y"},"prioritySymbols":{"H":"high","M":"medium","L":"low"},"todoIntegration":false,"createTaskSelectionType":"selection2link","taskCompleteStatus":["done","x"]},"graph":{"zoomSpeed":1,"createStub":false},"e