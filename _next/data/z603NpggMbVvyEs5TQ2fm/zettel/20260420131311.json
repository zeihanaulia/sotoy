{"pageProps":{"note":{"id":"zettel.20260420131311","title":"Kolaborasi manusia multi-hari memindahkan memori kerja ke dokumen bersama","desc":"Kalau kerja fitur berhari-hari, tim biasanya simpan konteksnya di dokumen kerja, bukan di kepala.","tags":["zettel","ai-collaboration","knowledge-management","context-anchoring"],"custom":{},"fname":"zettel.20260420131311","type":"note","vault":{"fsPath":"vault"},"contentHash":"53014bcc96afc141f0c7b989bec9e7e0","updated":1776683200456,"created":1776683200456,"links":[{"type":"frontmatterTag","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"tags.zettel","alias":"zettel","xvault":false,"to":{"fname":"tags.zettel"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"tags.ai-collaboration","alias":"ai-collaboration","xvault":false,"to":{"fname":"tags.ai-collaboration"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"tags.knowledge-management","alias":"knowledge-management","xvault":false,"to":{"fname":"tags.knowledge-management"}},{"type":"frontmatterTag","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"tags.context-anchoring","alias":"context-anchoring","xvault":false,"to":{"fname":"tags.context-anchoring"}},{"type":"wiki","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"zettel.literature.context-anchoring","position":{"start":{"line":16,"column":13,"offset":924},"end":{"line":16,"column":52,"offset":963},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.context-anchoring"}},{"type":"wiki","from":{"fname":"zettel.20260420131311","id":"zettel.20260420131311","vaultName":"vault"},"value":"zettel.20260420131310","position":{"start":{"line":17,"column":14,"offset":1010},"end":{"line":17,"column":39,"offset":103