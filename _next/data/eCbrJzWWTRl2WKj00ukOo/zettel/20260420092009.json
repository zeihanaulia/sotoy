name":"zettel.20260420092009","id":"zettel.20260420092009","vaultName":"vault"},"value":"zettel.literature.software-architecture-guide","position":{"start":{"line":20,"column":3,"offset":1005},"end":{"line":20,"column":52,"offset":1054},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.software-architecture-guide"}},{"type":"wiki","from":{"fname":"zettel.20260420092009","id":"zettel.20260420092009","vaultName":"vault"},"value":"zettel.20260420091825","position":{"start":{"line":21,"column":3,"offset":1057},"end":{"line":21,"column":28,"offset":1082},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260420091825"}},{"type":"wiki","from":{"fname":"zettel.20260420092009","id":"zettel.20260420092009","vaultName":"vault"},"value":"zettel.literature.enterprise-architecture-coordination-cost","position":{"start":{"line":22,"column":3,"offset":1136},"end":{"line":22,"column":66,"offset":1199},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.literature.enterprise-architecture-coordination-cost"}},{"type":"wiki","from":{"fname":"zettel.20260420092009","id":"zettel.20260420092009","vaultName":"vault"},"value":"zettel.20260420091306","position":{"start":{"line":23,"column":3,"offset":1263},"end":{"line":23,"column":28,"offset":1288},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"zettel.20260420091306"}},{"from":{"fname":"zettel","id":"zettel","vaultName":"vault"},"type":"backlink","position":{"start":{"line":50,"column":3,"offset":3788},"end":{"line":50,"column":28,"offset":3813},"indent":[]},"value":"zettel.20260420092009"},{"from":{"fname":"zettel.20260420092459","id":"zettel.20260420092459","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1491},"end":{"line":22,"column":28,"offset":1516},"indent":[]},"value":"zettel.20260420092009"},{"from":{"fname":"zettel.20260420092652","id":"zettel.20260420092652","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1083},"end":{"line":22,"column":28,"offset":1108},"indent":[]},"value":"zettel.20260420092009"},{"from":{"fname":"zettel.20260420092900","id":"zettel.20260420092900","vaultName":"vault"},"type":"backlink","position":{"start":{"line":21,"column":3,"offset":1082},"end":{"line":21,"column":28,"offset":1107},"indent":[]},"value":"zettel.20260420092009"},{"from":{"fname":"zettel.20260420092901","id":"zettel.20260420092901","vaultName":"vault"},"type":"backlink","position":{"start":{"line":25,"column":3,"offset":1826},"end":{"line":25,"column":28,"offset":1851},"indent":[]},"value":"zettel.20260420092009"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":83,"column":3,"offset":6816},"end":{"line":83,"column":28,"offset":6841},"indent":[]},"value":"zettel.20260420092009"}],"anchors":{},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"sentralisasi-total-di-ea-melambatkan-keputusan-dan-kehilangan-konteks-lokal\">Sentralisasi total di EA melambatkan keputusan dan kehilangan konteks lokal<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sentralisasi-total-di-ea-melambatkan-keputusan-dan-kehilangan-konteks-lokal\"></a></h1>\n<blockquote>\n<p>At one extreme is a central architecture group that must approve all architectural decision for every software system in the enterprise. Such groups slow down decision making and cannot truly understand the issues across such a wide portfolio of systems, leading to poor decision-making.</p>\n<p>Sumber: <a href=\"https://martinfowler.com/architecture/\">https://martinfowler.com/architecture/</a></p>\n</blockquote>\n<p>Catatan gue:</p>\n<ul>\n<li>Ekstrem pertama yang dibahas Fowler adalah kelompok arsitektur pusat yang harus menyetujui semua keputusan.</li>\n<li>Model ini melambatkan pengambilan keputusan dan kehilangan konteks lokal yang penting.</li>\n<li>Kritiknya langsung ke governance yang jauh dari realitas delivery.</li>\n</ul>\n<p>Implikasi:</p>\n<ul>\n<li>Sentralisasi total gagal karena informasi lokal terlalu kaya untuk diringkas ke meja approval pusat.</li>\n<li>Central architecture group berisiko menjadi bottleneck dan membuat keputusan buruk karena jarak dari tim pelaksana.</li>\n<li>Enterprise architecture harus mempertimbangkan mekanisme lain selain approval pusat untuk menjaga kecepatan dan pemahaman domain.</li>\n</ul>\n<p>Hubungan:</p>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.software-architecture-guide\">Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420091825\">Enterprise architecture adalah soal apakah biaya koordinasi pusat layak</a> — evaluasi biaya koordinasi pusat vs otonomi lokal</li>\n<li><a href=\"/sotoy/notes/zettel.literature.enterprise-architecture-coordination-cost\">Enterprise architecture adalah soal biaya koordinasi, bukan kontrol total</a> — kritik terhadap sentralisasi total sebagai opsi koordinasi</li>\n<li><a href=\"/sotoy/notes/zettel.20260420091306\">Enterprise architecture bergeser ke koordinasi antar-pulau, bukan lagi modularitas kode</a> — pergeseran fokus arsitektur aplikasi ke enterprise coordination</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">permanent-note (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">software-architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">enterprise-architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">governance (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">coordination (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">martin-fowler (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420092459\">Otonomi tanpa koordinasi di EA berubah jadi fragmentasi mahal</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420092652\">Fowler condong ke desentralisasi tetapi tetap waspada terhadap chaos</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420092900\">Enterprise architects lebih efektif ketika ikut masuk ke tim pengembangan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420092901\">Enterprise architecture Fowler: organisasi, funding, komunikasi, dan learning system</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"dendronVersion":"0.83.0","vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y.MM.dd","addBehavior":"childOfDomain"},"scratch":{"name":"scratch","dateFormat":"y.MM.dd.HHmmss","addBehavior":"asOwnDomain"},"task":{"name":"","dateFormat":"","addBehavior":"childOfCurrent","statusSymbols":{"":" ","wip":"w","done":"x","assigned":"a","moved":"m","blocked":"b","delegated":"l","dropped":"d","pending":"y"},"prioritySymbols":{"H":"high","M":"medium","L":"low"},"todoIntegration":false,"createTaskSelectionType":"selection2link","taskCompleteStatus":["done","x"]},"graph":{"zoomSpeed":1,"createStub":false},"enableAutoCreateOnDefinition":false,"enableXVaultWikiLink":false,"enableRemote