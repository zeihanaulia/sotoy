me":"vault"},"type":"backlink","position":{"start":{"line":21,"column":3,"offset":1339},"end":{"line":21,"column":28,"offset":1364},"indent":[]},"value":"zettel.20260420085349"},{"from":{"fname":"zettel.20260420090327","id":"zettel.20260420090327","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1465},"end":{"line":22,"column":28,"offset":1490},"indent":[]},"value":"zettel.20260420085349"},{"from":{"fname":"zettel.20260420090627","id":"zettel.20260420090627","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1377},"end":{"line":22,"column":28,"offset":1402},"indent":[]},"value":"zettel.20260420085349"},{"from":{"fname":"zettel.20260420090829","id":"zettel.20260420090829","vaultName":"vault"},"type":"backlink","position":{"start":{"line":27,"column":3,"offset":1516},"end":{"line":27,"column":28,"offset":1541},"indent":[]},"value":"zettel.20260420085349"},{"from":{"fname":"zettel.20260420091306","id":"zettel.20260420091306","vaultName":"vault"},"type":"backlink","position":{"start":{"line":22,"column":3,"offset":1431},"end":{"line":22,"column":28,"offset":1456},"indent":[]},"value":"zettel.20260420085349"},{"from":{"fname":"zettel.moc.software-architecture","id":"zettel.moc.software-architecture","vaultName":"vault"},"type":"backlink","position":{"start":{"line":44,"column":3,"offset":2679},"end":{"line":44,"column":28,"offset":2704},"indent":[]},"value":"zettel.20260420085349"}],"anchors":{},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"keputusan-arsitektural-penting-bergantung-pada-skala-sistem\">Keputusan arsitektural penting bergantung pada skala sistem<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#keputusan-arsitektural-penting-bergantung-pada-skala-sistem\"></a></h1>\n<blockquote>\n<p>\"The important decisions in software development vary with the scale of the context that we're thinking about. A common scale is that of an application, hence 'application architecture'.\"</p>\n<p>Sumber: <a href=\"https://martinfowler.com/architecture/\">https://martinfowler.com/architecture/</a></p>\n</blockquote>\n<p>Catatan gue:</p>\n<ul>\n<li>Paragraf ini membuat transisi penting dari definisi arsitektur sebagai \"important stuff\" ke pemahaman bahwa \"important\" bersifat relatif terhadap skala.</li>\n<li>Level aplikasi adalah salah satu skala umum untuk menilai keputusan arsitektural.</li>\n<li>Ini menegaskan bahwa tidak ada keputusan arsitektural yang penting secara absolut.</li>\n</ul>\n<p>Implikasi:</p>\n<ul>\n<li>Sebuah keputusan bisa menjadi krusial di level service tetapi kurang penting di level aplikasi, atau sebaliknya.</li>\n<li>Tim harus mengidentifikasi skala konteks sebelum menetapkan prioritas arsitektural.</li>\n<li>Perhatian arsitektural perlu disesuaikan dengan skala sistem: service, aplikasi, enterprise.</li>\n</ul>\n<p>Hubungan:</p>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.software-architecture-guide\">Software Architecture Guide — Fowler: arsitektur sebagai keputusan penting dan mahal kalau salah</a> — ringkasan halaman Software Architecture Guide</li>\n<li><a href=\"/sotoy/notes/zettel.literature.application-boundary-social-construction\">Application boundary adalah konstruksi sosial</a> — aplikasi sebagai konstruksi sosial</li>\n<li><a href=\"/sotoy/notes/zettel.literature.enterprise-architecture-coordination-cost\">Enterprise architecture adalah soal biaya koordinasi, bukan kontrol total</a> — enterprise architecture sebagai biaya koordinasi</li>\n<li><a href=\"/sotoy/notes/zettel.20260420061530\">Architecture adalah seni memilah keputusan penting</a> — architecture adalah seni memilah keputusan penting</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">permanent-note (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">software-architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">architecture (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">martin-fowler (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420085507\">Boundary aplikasi adalah konstruksi sosial, bukan fakta alam</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420085834\">Microservices adalah trade-off machine, bukan arsitektur modern otomatis</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090017\">Modernisasi yang matang adalah displacement bertahap, bukan rewrite besar</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090203\">Micro Frontends menunjukkan arsitektur juga soal koordinasi tim</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090327\">GUI Architectures: pattern harus diikuti prinsip, bukan label familiar</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090627\">Serverless mengurangi operasi tapi menambah ketergantungan platform</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420090829\">Presentation Domain Data Layering adalah baseline, bukan arsitektur kuno</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420091306\">Enterprise architecture bergeser ke koordinasi antar-pulau, bukan lagi modularitas kode</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.software-architecture\">MOC: Software Architecture</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"title"},"templateHierarchy":"template"},"workspace":{"dendronVersion":"0.83.0","vaults":[{"fsPath":"vault"}],"journal":{"dailyDomain":"daily","name":"journal","dateFormat":"y