":"vault"},"type":"backlink","position":{"start":{"line":13,"column":14,"offset":307},"end":{"line":13,"column":39,"offset":332},"indent":[]},"value":"zettel.20260420131310"},{"from":{"fname":"zettel.20260420131434","id":"zettel.20260420131434","vaultName":"vault"},"type":"backlink","position":{"start":{"line":13,"column":14,"offset":287},"end":{"line":13,"column":39,"offset":312},"indent":[]},"value":"zettel.20260420131310"},{"from":{"fname":"zettel.20260420131435","id":"zettel.20260420131435","vaultName":"vault"},"type":"backlink","position":{"start":{"line":41,"column":14,"offset":1696},"end":{"line":41,"column":39,"offset":1721},"indent":[]},"value":"zettel.20260420131310"},{"from":{"fname":"zettel.literature.context-anchoring","id":"zettel.literature.context-anchoring","vaultName":"vault"},"type":"backlink","position":{"start":{"line":145,"column":3,"offset":8993},"end":{"line":145,"column":28,"offset":9018},"indent":[]},"value":"zettel.20260420131310"}],"anchors":{"gagasan":{"type":"header","text":"Gagasan","value":"gagasan","line":13,"column":0,"depth":2},"mengapa-ini-penting":{"type":"header","text":"Mengapa Ini Penting","value":"mengapa-ini-penting","line":17,"column":0,"depth":2},"penjelasan":{"type":"header","text":"Penjelasan","value":"penjelasan","line":21,"column":0,"depth":2},"contoh-kasus":{"type":"header","text":"Contoh Kasus","value":"contoh-kasus","line":29,"column":0,"depth":2},"implikasi-praktis":{"type":"header","text":"Implikasi Praktis","value":"implikasi-praktis","line":34,"column":0,"depth":2},"pertanyaan-untuk-ditindaklanjuti":{"type":"header","text":"Pertanyaan Untuk Ditindaklanjuti","value":"pertanyaan-untuk-ditindaklanjuti","line":39,"column":0,"depth":2},"hubungan-ke-zettel-lain":{"type":"header","text":"Hubungan ke Zettel Lain","value":"hubungan-ke-zettel-lain","line":45,"column":0,"depth":2},"sumber":{"type":"header","text":"Sumber","value":"sumber","line":51,"column":0,"depth":2}},"children":[],"parent":"zettel","data":{}},"body":"<h1 id=\"percakapan-ai-adalah-medium-berpikir-bukan-tempat-penyimpanan-keputusan\">Percakapan AI adalah medium berpikir, bukan tempat penyimpanan keputusan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#percakapan-ai-adalah-medium-berpikir-bukan-tempat-penyimpanan-keputusan\"></a></h1>\n<h2 id=\"gagasan\">Gagasan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#gagasan\"></a></h2>\n<p>Chat AI itu cuma ruang berpikir sementara. Keputusan penting yang cuma hidup di chat cepat memudar begitu sesi memanjang, dan tidak ada yang bertahan setelah sesi berakhir.</p>\n<h2 id=\"mengapa-ini-penting\">Mengapa Ini Penting<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#mengapa-ini-penting\"></a></h2>\n<p>AI-assisted development bukan cuma soal ngoding. Ini soal gimana desain, asumsi, dan alasan keputusan bisa dilanjutkan ke sesi-sesi berikutnya tanpa bolak-balik nanya lagi.</p>\n<h2 id=\"penjelasan\">Penjelasan<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#penjelasan\"></a></h2>\n<p>Percakapan dengan model besar itu efektif buat nyetak ide: cepat, iteratif, dan fleksibel. Masalahnya, banyak keputusan dan alasan (the why) yang muncul cuma hidup di alur chat — dan itu rentan hilang:</p>\n<ul>\n<li>Context window yang terbatas dan pergantian topik bikin informasi penting sulit direkonstruksi.</li>\n<li>Chat jarang menyimpan metadata: siapa bilang apa, asumsi apa yang dipakai, atau referensi ke file/issue.</li>\n<li>Tanpa ringkasan persisten, keputusan bisa terabaikan atau ter-revert karena alasan aslinya nggak terdokumentasi.</li>\n</ul>\n<h2 id=\"contoh-kasus\">Contoh Kasus<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#contoh-kasus\"></a></h2>\n<ul>\n<li>Desainer memutuskan perubahan UX di sesi brainstorming; implementor bingung karena gak ada alasan tertulis, akhirnya revert.</li>\n<li>Arsitek memilih trade-off performa vs maintainability dalam chat; evaluasi berikutnya sulit karena alasan awal tidak terdokumentasi.</li>\n</ul>\n<h2 id=\"implikasi-praktis\">Implikasi Praktis<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#implikasi-praktis\"></a></h2>\n<ul>\n<li>Terapkan \"context-anchoring\": sebelum menutup sesi, minta ringkasan 2–3 baris berisi keputusan, alasan singkat, dan referensi (file/issue).</li>\n<li>Standarisasi format ringkasan supaya mudah diotomasi (contoh: satu baris YAML/frontmatter kecil, atau template yang bisa diparsing).</li>\n</ul>\n<h2 id=\"pertanyaan-untuk-ditindaklanjuti\">Pertanyaan Untuk Ditindaklanjuti<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-untuk-ditindaklanjuti\"></a></h2>\n<ol>\n<li>Kriteria apa yang membuat keputusan layak dipromosikan ke Zettel permanent? (impact, scope, lifetime)</li>\n<li>Siapa bertanggung jawab memindahkan ringkasan sesi ke penyimpanan persisten?</li>\n<li>Bisakah dibuat tooling kecil (template/shortcut) yang memaksa ringkasan sebelum menutup sesi chat?</li>\n</ol>\n<h2 id=\"hubungan-ke-zettel-lain\">Hubungan ke Zettel Lain<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#hubungan-ke-zettel-lain\"></a></h2>\n<ul>\n<li>Mendukung <a href=\"/sotoy/notes/zettel.literature.context-anchoring\">Context Anchoring — memindahkan konteks keputusan dari chat ke dokumen hidup</a> — klaim diambil dari Paragraf 0.</li>\n<li>Lihat juga <a href=\"/sotoy/notes/zettel.20260420131311\">Kolaborasi manusia multi-hari memindahkan memori kerja ke dokumen bersama</a> — baseline kolaborasi manusia yang transfer konteks ke dokumen (relevan karena membahas proses transfer konteks).</li>\n<li>Terkait: <a href=\"/sotoy/notes/zettel.20260420131312\">AI memory tools sekarang kebanyakan project-level, bukan feature-level</a> — praktik membuat ringkasan keputusan otomatis.</li>\n</ul>\n<h2 id=\"sumber\">Sumber<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sumber\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.literature.context-anchoring\">Context Anchoring — memindahkan konteks keputusan dari chat ke dokumen hidup</a> — Paragraf 0</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a class=\"color-tag\" style=\"--tag-color: #a03623;\" href=\"/sotoy/notes/tags.zettel\">zettel</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">ai-collaboration (Private)</a></li>\n<li><a class=\"color-tag\" style=\"--tag-color: #f0944d;\" href=\"/sotoy/notes/tags.knowledge-management\">knowledge-management</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">context-anchoring (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131311\">Kolaborasi manusia multi-hari memindahkan memori kerja ke dokumen bersama</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131312\">AI memory tools sekarang kebanyakan project-level, bukan feature-level</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131400\">Kecemasan menutup chat adalah indikator context leakage</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131401\">Erosi konteks AI adalah isu arsitektural, bukan bug acak</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131402\">Context window besar tetap cepat habis dalam praktik engineering</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131403\">Posisi informasi memengaruhi recall; tengah konteks adalah zona rawan hilang</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131404\">Dalam erosi konteks, why hilang sebelum what</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131405\">Kalau medium lupa, pindahkan memori ke luar medium itu</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131406\">Summarization otomatis menyelamatkan what, bukan why</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131407\">Alignment tanpa persistence tetap rapuh</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131408\">Context anchoring adalah durability layer untuk alignment manusia-AI</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131409\">Decision context harus menjadi external state, bukan jejak chat</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131410\">Project context dan feature context punya fungsi berbeda</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131411\">Priming document adalah memori stabil level proyek</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131412\">Feature document adalah memori dinamis level pekerjaan yang sedang berlangsung</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131413\">Agar efektif, AI butuh dua lapis konteks: fondasi stabil dan riwayat lokal</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131414\">Membaca codebase tidak sama dengan memahami keputusan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131415\">Code menyimpan outcome; reasoning dan rejected history tidak tampak di sana</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131416\">Feature document lebih semantik-padatan dan token-efisien daripada mengekstrak reasoning dari kode</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131417\">Context anchoring untuk AI adalah versi kontemporer dari kebutuhan yang melahirkan ADR</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131418\">Feature document adalah ADR hidup selama proses, bukan catatan pasca-fakta</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131419\">Feature document bisa jadi jembatan antara kerja harian dan dokumentasi formal</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131420\">Context anchoring adalah infrastruktur koordinasi tim, bukan hanya memori individu</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131421\">Dokumen adalah mekanisme persistence yang menggantikan keterbatasan model</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131422\">Solusi ini bisa dipasang ke contoh praktis, bukan sekadar teori</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131423\">Begitu keputusan desain terkristal, pindahkan ke dokumen bersama alasannya</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131424\">Feature document yang efektif itu ringkas dan operasional</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131425\">Struktur minimal feature document jelas dan praktis</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131426\">Nilai anchoring muncul saat sesi baru bisa warm start</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131427\">Maintenance dokumen harus menempel ke ritme kerja alami</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131428\">Feature document memaksa reasoning menjadi lebih jelas</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131429\">Feature document mengompresi hari kerja menjadi konteks yang bisa diakses ulang cepat</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131430\">Context anchoring adalah alat yang harus dikalibrasi, bukan default universal</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131431\">Kebutuhan anchoring naik seiring durasi, revisit, dan jumlah orang</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131432\">Nilai anchoring ditentukan oleh overhead dokumentasi versus biaya kehilangan konteks</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131433\">Keinginan mempertahankan chat adalah indikator anchoring belum cukup</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131434\">Chat adalah medium berpikir; dokumen adalah medium penyimpanan keputusan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260420131435\">Keberhasilan context anchoring diukur dari murahnya restart</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.context-anchoring\">Context Anchoring — memindahkan konteks keputusan dari chat ke dokumen hidup</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink":{"aliasMode":"none","enableMultiSelect":false},"insertNoteIndex":{"enableMarker":false},"copyNoteLink":{"aliasMode":"