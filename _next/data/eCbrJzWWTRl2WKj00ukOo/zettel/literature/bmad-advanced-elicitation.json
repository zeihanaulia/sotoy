et":2151},"end":{"line":51,"column":50,"offset":2198},"indent":[]},"value":"zettel.literature.bmad-advanced-elicitation"},{"from":{"fname":"zettel.literature.bmad-party-mode","id":"zettel.literature.bmad-party-mode","vaultName":"vault"},"type":"backlink","position":{"start":{"line":48,"column":3,"offset":1833},"end":{"line":48,"column":50,"offset":1880},"indent":[]},"value":"zettel.literature.bmad-advanced-elicitation"},{"from":{"fname":"zettel.moc.ai-native","id":"zettel.moc.ai-native","vaultName":"vault"},"type":"backlink","position":{"start":{"line":16,"column":3,"offset":838},"end":{"line":16,"column":50,"offset":885},"indent":[]},"value":"zettel.literature.bmad-advanced-elicitation"}],"anchors":{"pertanyaan-yang-dibuka":{"type":"header","text":"Pertanyaan yang dibuka","value":"pertanyaan-yang-dibuka","line":15,"column":0,"depth":2},"ringkasan-literatur":{"type":"header","text":"Ringkasan literatur","value":"ringkasan-literatur","line":21,"column":0,"depth":2},"ide-penting":{"type":"header","text":"Ide penting","value":"ide-penting","line":44,"column":0,"depth":2},"interpretasi":{"type":"header","text":"Interpretasi","value":"interpretasi","line":51,"column":0,"depth":2},"sumber":{"type":"header","text":"Sumber","value":"sumber","line":55,"column":0,"depth":2},"lihat-juga":{"type":"header","text":"Lihat juga","value":"lihat-juga","line":59,"column":0,"depth":2}},"children":[],"parent":"ae3bw38eg7l5p3ntry27x87","data":{}},"body":"<h1 id=\"bmad-advanced-elicitation-sebagai-literature-note\">BMAD Advanced Elicitation sebagai literature note<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#bmad-advanced-elicitation-sebagai-literature-note\"></a></h1>\n<h2 id=\"pertanyaan-yang-dibuka\">Pertanyaan yang dibuka<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#pertanyaan-yang-dibuka\"></a></h2>\n<ol>\n<li>Mengapa perintah \"make it better\" terlalu kabur untuk second pass AI?</li>\n<li>Bagaimana metode berpikir terstruktur mengubah kualitas reconsideration output?</li>\n<li>Kapan Advanced Elicitation paling cocok dipakai dalam workflow BMAD?</li>\n</ol>\n<h2 id=\"ringkasan-literatur\">Ringkasan literatur<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ringkasan-literatur\"></a></h2>\n<p>Halaman BMAD Advanced Elicitation menjelaskan bahwa second pass AI harus dipandu oleh metode berpikir eksplisit, bukan sekadar diminta kembali menghasilkan output.</p>\n<p>BMAD memecah proses ini menjadi:</p>\n<ul>\n<li>output awal,</li>\n<li>pilihan metode berpikir,</li>\n<li>rerun model dengan metode itu,</li>\n<li>evaluasi manusia terhadap hasilnya.</li>\n</ul>\n<p>Karena banyak output AI bisa terlihat \"cukup baik\" tanpa benar-benar teruji, pendekatan ini bekerja dengan mengenalkan epistemic lens ke dalam revisi.</p>\n<p>Contoh metode yang disorot meliputi:</p>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421184801\">Pre-mortem analysis memaksa perencanaan menilai hasil dengan asumsi kegagalan</a> — pre-mortem analysis,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184812\">First principles thinking menuntut solusi dibangun dari fakta paling dasar</a> — first principles thinking,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184823\">Inversion mencari jalur gagal untuk menguji validitas desain</a> — inversion,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184834\">Red team vs blue team menguji ketahanan argumen lewat serangan dan pembelaan</a> — red team vs blue team,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184845\">Socratic questioning mengungkap asumsi lewat pertanyaan terarah</a> — socratic questioning,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184856\">Stakeholder mapping membuka risiko lewat banyak perspektif</a> — stakeholder mapping,</li>\n<li><a href=\"/sotoy/notes/zettel.20260421184907\">Constraint removal mengecek apakah batasan itu nyata atau sekadar asumsi</a> — constraint removal.</li>\n</ul>\n<h2 id=\"ide-penting\">Ide penting<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ide-penting\"></a></h2>\n<ul>\n<li>Advanced Elicitation menukar \"retry\" dengan \"reconsider with a specific thinking mode.\" </li>\n<li>Nilainya terbesar saat output awal berpotensi menipu karena terlihat masuk akal.</li>\n<li>Metode harus dipilih berdasarkan objek: spec, plan, architecture, dan artefak high-stakes lain.</li>\n<li>Hasilnya tetap memerlukan keputusan manusia; rerun bukan otomatis lebih baik.</li>\n</ul>\n<h2 id=\"interpretasi\">Interpretasi<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#interpretasi\"></a></h2>\n<p>Halaman ini menegaskan bahwa peningkatan output AI bukan hanya soal variasi; itu soal memberi model kerangka berpikir baru untuk mengevaluasi ulang karyanya.</p>\n<h2 id=\"sumber\">Sumber<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#sumber\"></a></h2>\n<ul>\n<li><a href=\"https://docs.bmad-method.org/explanation/advanced-elicitation/\">https://docs.bmad-method.org/explanation/advanced-elicitation/</a></li>\n</ul>\n<h2 id=\"lihat-juga\">Lihat juga<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#lihat-juga\"></a></h2>\n<ul>\n<li><a href=\"/sotoy/notes/zettel.20260421184757\">Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</a> — Advanced Elicitation memaksa model menggunakan lensa berpikir eksplisit untuk reconsider output</li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-adversarial-review\">BMAD Adversarial Review sebagai literature note</a> — literature note BMAD Adversarial Review</li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">zettel.literature.checkpoint-preview (Private)</a> — literature note BMAD Checkpoint Preview</li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a> — MOC AI-native engineering</li>\n</ul>\n<hr>\n<h2 id=\"tags\">Tags<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#tags\"></a></h2>\n<ol>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">bmad (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">advanced-elicitation (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">literature (Private)</a></li>\n<li><a title=\"Private\" href=\"https://wiki.dendron.so/notes/hfyvYGJZQiUwQaaxQO27q.html\" target=\"_blank\" class=\"private\">reasoning (Private)</a></li>\n</ol>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/sotoy/notes/zettel\">Zettelkasten</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184801\">Pre-mortem analysis memaksa perencanaan menilai hasil dengan asumsi kegagalan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184812\">First principles thinking menuntut solusi dibangun dari fakta paling dasar</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184823\">Inversion mencari jalur gagal untuk menguji validitas desain</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184834\">Red team vs blue team menguji ketahanan argumen lewat serangan dan pembelaan</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184845\">Socratic questioning mengungkap asumsi lewat pertanyaan terarah</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184856\">Stakeholder mapping membuka risiko lewat banyak perspektif</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421184907\">Constraint removal mengecek apakah batasan itu nyata atau sekadar asumsi</a></li>\n<li><a href=\"/sotoy/notes/zettel.20260421185424\">Party Mode adalah mesin konflik terkontrol untuk menampilkan trade-off multi-agent</a></li>\n<li><a href=\"/sotoy/notes/zettel.literature.bmad-party-mode\">BMAD Party Mode sebagai literature note</a></li>\n<li><a href=\"/sotoy/notes/zettel.moc.ai-native\">MOC AI-native engineering</a></li>\n</ul>","noteIndex":{"id":"root","title":"Hello and Welcome! 👋","desc":"","updated":1742030256619,"created":1646842475821,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"453f88f4a5f1ad7629ebb7cc49502125","links":[],"anchors":{"find-more":{"type":"header","text":"Find More","value":"find-more","line":20,"column":0,"depth":2}},"children":["book-summaries","daily","handbook","notes","tags","til","zettel"],"parent":null,"data":{},"body":"\nWelcome to the homepage! I use Dendron to store and organize notes, ideas, and experiments I’m working on. Here are the main sections you’ll find on this site:\n\n1. **Learning Notes** — Practical notes on programming, recent technologies, and productivity tips.\n2. **Personal Projects** — Summaries of projects, experiments, and outcomes I’m working on or have completed.\n3. **Writings & Opinions** — Casual articles and reflections about technology, daily life, and other interesting topics.\n\nI’m constantly experimenting and learning. I hope the content here helps you as a reference, a starting point for discussion, or just light reading.\n\n> Why Dendron?\n>\nDendron helps keep notes organized. Its \"seed\" and \"vault\" concepts make it easy to structure content and find what you need.\n\n## Find More\n\nIf you want to learn more or connect, check these links:\n\n- [Homepage (Dendron)](https://zeihanaulia.github.io/sotoy/)\n- [My GitHub](https://github.com/zeihanaulia)\n- [My Twitter / X](https://x.com/zeihanaulia)\n\nThanks for stopping by. If you have feedback or want to chat, feel free to reach out.\n"},"collectionChildren":null,"customHeadContent":null,"config":{"version":5,"dev":{"enablePreviewV2":true},"commands":{"lookup":{"note":{"selectionMode":"extract","confirmVaultOnCreate":true,"vaultSelectionModeOnCreate":"smart","leaveTrace":false,"bubbleUpCreateNew":true,"fuzzThreshold":0.2}},"randomNote":{},"insertNoteLink